---
const { title, description } = Astro.props;
---

<div class="relative z-20 w-full mx-auto lg:mx-0">
  <h2
    class="text-2xl font-playfair font-extrabold tracking-tight text-[#7699d4] sm:text-3xl lg:text-4xl"
  >
    {title}
  </h2>
  <p
    class="mt-3 text-sm leading-6 text-text dark:text-text sm:mt-4 lg:mt-6 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
  >
    {description}
  </p>
</div>
