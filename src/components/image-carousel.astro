---
const { slides = [] } = Astro.props;
---

<div class="relative w-full overflow-hidden" data-carousel>
  <div class="flex transition-transform duration-500 ease-in-out carousel-track">
    {slides.map((slide) => (
      <div class="min-w-full flex-shrink-0">

        <!-- Image -->
        <div class="max-h-[500px] aspect-[3/5] md:aspect-[5/4] w-full rounded-xl overflow-hidden">
            <img
            src={slide.image}
            alt={slide.alt}
            class="w-full h-full object-cover block"
            />
        </div>
        
        <!-- Caption -->
        {slide.caption && (
          <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400 text-center">
            {slide.caption}
          </p>
        )}

      </div>
    ))}
  </div>

  

  <!-- Controls -->
  <button
    data-carousel-button="prev"
    class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/50 text-white px-3 py-1 rounded"
  >
    ←
  </button>
  <button
    data-carousel-button="next"
    class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/50 text-white px-3 py-1 rounded"
  >
    →
  </button>
</div>